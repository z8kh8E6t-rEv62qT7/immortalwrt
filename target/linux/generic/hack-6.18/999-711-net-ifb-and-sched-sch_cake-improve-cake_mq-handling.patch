+static u16 ifb_select_queue(struct net_device *dev, struct sk_buff *skb,
+			    struct net_device *sb_dev)
+{
+	u16 qcount = dev->real_num_tx_queues;
+
+	if (qcount <= 1)
+		return 0;
+
+	/* Redirected ingress packets often share the same recorded RX queue.
+	 * Use the packet flow hash so multiqueue IFBs can spread them across
+	 * their TX queues instead of collapsing onto a single queue.
+	 */
+	return reciprocal_scale(skb_get_hash(skb), qcount);
+}
