MT7622()
{
	num_of_wifi=$1
	DEFAULT_RPS=0

	#Physical IRQ# setting
	eth0_irq=224
	eth1_irq=225
	wifi1_irq=
	wifi2_irq=
	wifi3_irq=
	#AX1200 AX3200
	if [[ "$WIFI_RADIO1" -eq "1" ]]; then
		wifi1_irq=211
	fi
	#AX1800 AX3200
	if [[ "$WIFI_RADIO2" -eq "1" ]]; then
		wifi2_irq=214
	fi
	#AX3600
	if [[ "$WIFI_RADIO3" -eq "1" ]]; then
		wifi3_irq=215
	fi

	# Please update the CPU binding in each cases.
	# CPU#_AFFINITY="add binding irq number here"
	# CPU#_RPS="add binding interface name here"
	if [ "$num_of_wifi" == "0" ]; then
		CPU0_AFFINITY="$eth0_irq"
		CPU1_AFFINITY="$eth1_irq"

		CPU0_RPS="$RPS_IF_LIST"
		CPU1_RPS="$RPS_IF_LIST"
	else
		#we bound all wifi card to cpu0 and bound eth to cpu1
		CPU0_AFFINITY="$wifi1_irq $wifi2_irq $wifi3_irq"
		CPU1_AFFINITY="$eth0_irq $eth1_irq"

		CPU0_RPS="$RPS_IF_LIST"
		CPU1_RPS="$RPS_IF_LIST"
	fi

	logger -s "smp_affinity: CPU0_AFFINITY = $CPU0_AFFINITY"
	logger -s "smp_affinity: CPU1_AFFINITY = $CPU1_AFFINITY"
}

setup_model()
{
	board=$(board_name)
	logger -s "smp_affinity: Board name: $board"
	num_of_wifi=$NUM_WIFI_CARD

	if [[ $board == *"7988"* ]]; then
		logger -s "smp_affinity: setup_model: MT7988 NUM_WIFI_CARD=$num_of_wifi"
		MT7988 $num_of_wifi
	elif [[ $board == *"7986"* ]]; then
		logger -s "smp_affinity: setup_model: MT7986 NUM_WIFI_CARD=$num_of_wifi"
		MT7986 $num_of_wifi
	elif [[ $board == *"gl-mt6000"* ]]; then
		logger -s "smp_affinity: setup_model: gl-mt6000 NUM_WIFI_CARD=$num_of_wifi"
			gl_mt6000 $num_of_wifi
	elif [[ $board == *"7981"* ]]; then
		logger -s "smp_affinity: setup_model: MT7981 NUM_WIFI_CARD=$num_of_wifi"
		MT7981 $num_of_wifi
	elif [[ $board == *"gl-mt3000"* ]]; then
		logger -s "smp_affinity: setup_model: gl-mt3000 NUM_WIFI_CARD=$num_of_wifi"
			gl_mt3000 $num_of_wifi
	elif [[ $board == *"7622"* ]]; then
		logger -s "smp_affinity: setup_model: MT7622 NUM_WIFI_CARD=$num_of_wifi"
		MT7622 $num_of_wifi
	elif [[ $board == *"bpi-r4"* ]]; then
		logger -s "smp_affinity: setup_model: bpi-r4 NUM_WIFI_CARD=$num_of_wifi"
		MT7988 $num_of_wifi
	fi
}

get_virtual_irq()
{
	PHY_POS=`expr $NUM_OF_CPU + 3` #physical irq # position in /proc/interrups may vary with the number of CPU up
	target_phy_irq=$1
	cat /proc/interrupts | sed 's/:/ /g'| awk '$1 ~ /^[0-9]+$/' | while read line
	do
		set -- $line
		phy_irq=$(eval "echo \$$PHY_POS")
		if [ $phy_irq == $target_phy_irq ]; then
			echo $1
			return
		fi
	done
}

set_rps_cpu_bitmap()
{
	logger -s "smp_affinity: # Scan binding interfaces of each cpu"
	# suppose the value of interface_var is null or hex
	num=0
	while [ "$num" -lt "$NUM_OF_CPU" ];do
		cpu_bit=$((2 ** $num))
		eval rps_list=\$CPU${num}_RPS
		logger -s "smp_affinity: # CPU$num: rps_list=$rps_list"
		for i in $rps_list; do
			var=${VAR_PREFIX}_${i//'-'/_}
			var=${var//'.'/_}
			eval ifval=\$$var
			logger -s "smp_affinity: [var val before] \$$var=$ifval"
			if [ -z "$ifval" ]; then
				eval $var=$cpu_bit
			else
				eval $var=`expr $ifval + $cpu_bit`
			fi
			eval ifval=\$$var
			logger -s "smp_affinity: [rps val after]$i=$ifval"
		done
		num=`expr $num + 1`
	done
}

# $1: The default rps value. If rps of the interface is not setup, set $1 to it
set_rps_cpus()
{
	logger -s "smp_affinity: # Setup rps of the interfaces, $RPS_IF_LIST."
	for i in $RPS_IF_LIST; do
		var=${VAR_PREFIX}_${i//'-'/_}
		var=${var//'.'/_}
		eval cpu_map=\$$var
		if [ -d /sys/class/net/$i ]; then
			if [ -n "$cpu_map" ]; then
				cpu_map=`printf '%x' $cpu_map`
			elif [ -n "$1" ]; then
				cpu_map="$1"
			fi

			if [ -n "$cpu_map" ]; then
				for rxq in /sys/class/net/$i/queues/rx-*; do
					[ -d "$rxq" ] || continue
					logger -s "smp_affinity: echo $cpu_map > $rxq/rps_cpus"
					echo $cpu_map > "$rxq/rps_cpus"
				done
			fi
		fi
	done
}

set_smp_affinity()
{
	logger -s "smp_affinity: # Setup affinity of each physical irq."
	num=0
	while [ "$num" -lt "$NUM_OF_CPU" ];do
		eval smp_list=\$CPU${num}_AFFINITY
		for i in $smp_list; do
			cpu_bit=$((2 ** $num))
			virq=$(get_virtual_irq $i)
			#virq=$i
			logger -s "smp_affinity: irq p2v $i --> $virq"
			if [ ! -z $virq ]; then
				#logger -s "smp_affinity: echo $cpu_bit > /proc/irq/$virq/smp_affinity"
				echo $cpu_bit > /proc/irq/$virq/smp_affinity
			fi
		done
		num=`expr $num + 1`
	done
}


logger -s "smp_affinity: # RPS and AFFINITY Setting"
logger -s "smp_affinity: # NUM_OF_CPU=$NUM_OF_CPU"
VAR_PREFIX="autogen"
get_if_info
setup_model

rps_setting=$(uci get network.globals.packet_steering 2>/dev/null)
rps_type=$(uci get advanced.@advanced_packet_steering[0].advanced_packet_steering_enable 2>/dev/null)

if [ -z "$rps_setting" ] || [ "$rps_setting" = "0" ]; then
	if [ -z "$rps_type" ] || [ "$rps_type" != "0" ]; then
		set_rps_cpu_bitmap
		set_rps_cpus $DEFAULT_RPS
	else
		logger -s "smp_affinity: # RPS disabled"
	fi
else
	logger -s "smp_affinity: # RPS done by packet steering script"
fi


set_smp_affinity
#end of file
}

mtk_offloading()
{
	mtk_offloading_enable=$(uci get advanced.@defaults[0].mtk_offloading_enable 2>/dev/null || echo "x")
	if [ "$mtk_offloading_enable" == "1" ]; then
			logger -s "smp_affinity: Enabling mtk offloading"
			#TCP Binding
			iptables -I FORWARD -p tcp -m conntrack --ctstate RELATED,ESTABLISHED -j FLOWOFFLOAD --hw
			ip6tables -I FORWARD -p tcp -m conntrack --ctstate RELATED,ESTABLISHED -j FLOWOFFLOAD --hw
			#UDP Binding
			iptables -I FORWARD -p udp -j FLOWOFFLOAD --hw
			ip6tables -I FORWARD -p udp -j FLOWOFFLOAD --hw
			#Multicast skip Binding
			iptables -I FORWARD -m pkttype --pkt-type multicast -j ACCEPT
			ip6tables -I FORWARD -m pkttype --pkt-type multicast -j ACCEPT
	elif [ "$mtk_offloading_enable" == 0 ]; then
			logger -s "smp_affinity: Disabling mtk offloading"
			#TCP Binding
			iptables -D FORWARD -p tcp -m conntrack --ctstate RELATED,ESTABLISHED -j FLOWOFFLOAD --hw
			ip6tables -D FORWARD -p tcp -m conntrack --ctstate RELATED,ESTABLISHED -j FLOWOFFLOAD --hw
			#UDP Binding
			iptables -D FORWARD -p udp -j FLOWOFFLOAD --hw
			ip6tables -D FORWARD -p udp -j FLOWOFFLOAD --hw
			#Multicast skip Binding
			iptables -D FORWARD -m pkttype --pkt-type multicast -j ACCEPT
			ip6tables -D FORWARD -m pkttype --pkt-type multicast -j ACCEPT
	fi
}

load_mt7915e_from_modules_file()
{
	local module_file="/etc/modules.d/mt7915e"
	local modline

	[ -e "$module_file" ] || return 1

	modline=$(cat "$module_file" 2>/dev/null)
	[ -n "$modline" ] || modline="mt7915e"

	set -- $modline
	/sbin/modprobe "$@"
}

wait_for_mt7915e_runtime()
{
	local tries=0

	while [ "$tries" -lt 10 ]; do
		[ -e /sys/module/mt7915e/parameters/wed_enable ] && return 0
		sleep 1
		tries=$((tries + 1))
	done

	return 1
}

mt7915e_module_has_token()
{
	local module_file="$1"
	local wanted="$2"
	local token

	[ -e "$module_file" ] || return 1

	set -- $(cat "$module_file" 2>/dev/null)
	for token in "$@"; do
		[ "$token" = "$wanted" ] && return 0
	done

	return 1
}

append_mt7915e_module_token()
{
	local token="$1"

	case " $new_line " in
		*" $token "*)
			;;
		*)
			new_line="$new_line $token"
			;;
	esac
}

sync_mt7915e_wed_module_options()
{
	MODULE_FILE="/etc/modules.d/mt7915e"
	wed=$(uci -q get advanced.@defaults[0].wed_offloading 2>/dev/null)

	if [ -z "$wed" ]; then
		if mt7915e_module_has_token "$MODULE_FILE" "wed_enable=1"; then
			wed=1
		else
			wed=0
		fi

		uci set advanced.@defaults[0].wed_offloading="$wed" 2>/dev/null
		uci commit advanced 2>/dev/null
	fi

	case "$wed" in
		1|on|true|yes|enabled)
			wed=1
			;;
		*)
			wed=0
			;;
	esac

	if [ -e "$MODULE_FILE" ]; then
		old_content=$(cat "$MODULE_FILE" 2>/dev/null)
		new_line="mt7915e"
		wed_token_added=0

		set -- $old_content
		for token in "$@"; do
			case "$token" in
				mt7915e)
					;;
				wed_enable=*)
					if [ "$wed" = "1" ] && [ "$wed_token_added" = "0" ]; then
						append_mt7915e_module_token "wed_enable=1"
						wed_token_added=1
					fi
					;;
				*)
					append_mt7915e_module_token "$token"
					;;
			esac
		done

		if [ "$wed" = "1" ] && [ "$wed_token_added" = "0" ]; then
			append_mt7915e_module_token "wed_enable=1"
		fi

		if [ "$old_content" != "$new_line" ]; then
			printf '%s\n' "$new_line" > "$MODULE_FILE"
			logger -t advanced_setup "updated $MODULE_FILE to '$new_line'; reboot required for WED mode change"
			echo "0"
			return 0
		fi
	fi

	if [ -e /sys/module/mt7915e/parameters/wed_enable ]; then
		runtime_wed=$(cat /sys/module/mt7915e/parameters/wed_enable 2>/dev/null)
		if { [ "$wed" = "1" ] && [ "$runtime_wed" != "Y" ]; } || \
		   { [ "$wed" = "0" ] && [ "$runtime_wed" != "N" ]; }; then
			logger -t advanced_setup "mt7915e runtime WED state '$runtime_wed' differs from UCI '$wed'; reboot required"
			echo "0"
			return 0
		fi
	fi

	echo "0"
}

reprobe_mt7915e()
{
	local reprobe_ok=0

	logger -t advanced_setup "reprobing mt7915e to apply module option changes"

	/sbin/wifi down >/dev/null 2>&1
	sleep 2

	if grep -q '^mt7915e ' /proc/modules 2>/dev/null; then
		if ! /sbin/modprobe -r mt7915e >/dev/null 2>&1 && \
		   ! /sbin/rmmod mt7915e >/dev/null 2>&1; then
			logger -t advanced_setup "failed to unload mt7915e; attempting to restore Wi-Fi"
			/sbin/wifi up >/dev/null 2>&1
			return 1
		fi
	fi

	sleep 2

	if ! load_mt7915e_from_modules_file >/dev/null 2>&1; then
		logger -t advanced_setup "failed to reload mt7915e from /etc/modules.d/mt7915e"
	else
		reprobe_ok=1
	fi

	if [ "$reprobe_ok" -eq 1 ] && ! wait_for_mt7915e_runtime; then
		logger -t advanced_setup "mt7915e runtime files not ready after reprobe"
		reprobe_ok=0
	fi

	/sbin/wifi up >/dev/null 2>&1
	sleep 3

	if [ "$reprobe_ok" -ne 1 ]; then
		logger -t advanced_setup "mt7915e reprobe incomplete; Wi-Fi bring-up attempted as fallback"
		return 1
	fi

	advanced_runtime_setup

	logger -t advanced_setup "mt7915e reprobe completed"
	return 0
}

sync_mt7915e_airtime_module_options()
{
	MODULE_FILE="/etc/modules.d/mt7915e"
	atf=$(uci -q get advanced.@defaults[0].atf_enable 2>/dev/null)
	hwatf=$(uci -q get advanced.@defaults[0].hw_atf_enable 2>/dev/null || echo "0")

	if [ -z "$atf" ]; then
		if mt7915e_module_has_token "$MODULE_FILE" "expose_airtime_fairness=0"; then
			atf=1
		else
			atf=0
		fi

		uci set advanced.@defaults[0].atf_enable="$atf" 2>/dev/null
		uci commit advanced 2>/dev/null
	fi

	case "$atf" in
		1|on|true|yes|enabled)
			atf=1
			;;
		*)
			atf=0
			;;
	esac

	if [ "$atf" != "1" ] && [ "$hwatf" = "1" ]; then
		logger -t advanced_setup "HW-ATF requires ATF; forcing hw_atf_enable=0"
		uci set advanced.@defaults[0].hw_atf_enable='0'
		uci commit advanced
		hwatf=0
	fi

	if [ -e "$MODULE_FILE" ]; then
		old_content=$(cat "$MODULE_FILE" 2>/dev/null)
		new_line="mt7915e"
		atf_token_added=0

		set -- $old_content
		for token in "$@"; do
			case "$token" in
				mt7915e)
					;;
				expose_airtime_fairness=*)
					if [ "$atf" = "1" ] && [ "$atf_token_added" = "0" ]; then
						append_mt7915e_module_token "expose_airtime_fairness=0"
						atf_token_added=1
					fi
					;;
				*)
					append_mt7915e_module_token "$token"
					;;
			esac
		done

		if [ "$atf" = "1" ] && [ "$atf_token_added" = "0" ]; then
			append_mt7915e_module_token "expose_airtime_fairness=0"
		fi

		if [ "$old_content" != "$new_line" ]; then
			printf '%s\n' "$new_line" > "$MODULE_FILE"
			logger -t advanced_setup "updated $MODULE_FILE to '$new_line'; reboot required for Airtime Fairness mode change"
			echo "0"
			return 0
		fi
	fi

	if mt7915e_airtime_reboot_required; then
		runtime_atf=$(cat /sys/module/mt7915e/parameters/expose_airtime_fairness 2>/dev/null)
		logger -t advanced_setup "mt7915e runtime Airtime Fairness state '$runtime_atf' differs from UCI '$atf'; reboot required"
	fi

	echo "0"
}

mt7915e_airtime_reboot_required()
{
	local atf
	local runtime_atf

	[ -e /sys/module/mt7915e/parameters/expose_airtime_fairness ] || return 1

	atf=$(uci -q get advanced.@defaults[0].atf_enable 2>/dev/null || echo "0")
	case "$atf" in
		1|on|true|yes|enabled)
			atf=1
			;;
		*)
			atf=0
			;;
	esac

	runtime_atf=$(cat /sys/module/mt7915e/parameters/expose_airtime_fairness 2>/dev/null)

	{ [ "$atf" = "1" ] && [ "$runtime_atf" != "N" ]; } || \
	{ [ "$atf" = "0" ] && [ "$runtime_atf" != "Y" ]; }
}

sync_mt7915e_module_options()
{
	local wed_changed
	local atf_changed

	wed_changed=$(sync_mt7915e_wed_module_options)
	atf_changed=$(sync_mt7915e_airtime_module_options)

	if [ "$wed_changed" = "1" ] || [ "$atf_changed" = "1" ]; then
		echo "1"
	else
		echo "0"
	fi
}

hw_atf_setup()
{
	local FILE
	local found=0

	atf=$(uci get advanced.@defaults[0].atf_enable 2>/dev/null || echo "0")
	hwatf=$(uci get advanced.@defaults[0].hw_atf_enable 2>/dev/null || echo "0")

	if [ "$atf" != "1" ] && [ "$hwatf" = "1" ]; then
		hwatf=0
	fi

	if mt7915e_airtime_reboot_required; then
		logger -t advanced_setup "skipping HW-ATF runtime setup; reboot required for Airtime Fairness mode change"
		return 0
	fi

	for FILE in /sys/kernel/debug/ieee80211/*/mt76/vow; do
		[ -e "$FILE" ] || continue
		found=1
		logger -s "smp_affinity: HW-ATF available at $FILE"
		if [ "$atf" = "1" ]; then
			echo 'vow_atf_en=1' > "$FILE"
		else
			echo 'vow_atf_en=0' > "$FILE"
		fi
		
		if [ "$atf" = "1" ] && [ "$hwatf" = "1" ]; then
			echo 'vow_watf_en=1' > "$FILE"
		else
			echo 'vow_watf_en=0' > "$FILE"
		fi
		echo 'show_vow_info' > "$FILE"
	done

	[ "$found" -eq 1 ] || return 0
}

advanced_runtime_setup()
{
	smp_mt76
	enable_HQoS
	cake_mq_setup
	usb_setup
	hw_atf_setup
}

enable_HQoS()
{
	FILE="/sbin/mtkhnat"
	if [ -e "$FILE" ]; then
		mtkutil_enable=$(uci get mtkhnat.global.enable 2>/dev/null  || echo "x")
		hqos_enable=$(uci get mtkhnat.global.hqos 2>/dev/null  || echo "x")
		if [ $mtkutil_enable == 1 ]; then
			if [ $hqos_enable == 1 ]; then
				/sbin/mtkhnat
				logger -s "smp_affinity: mtkhnat_util is enabled and active"
			fi
		fi
	fi
	
}

cake_mq_setup()
{
	CAKE_SYNC_TIME_PATH="/sys/kernel/debug/cake_mq/sync_time_ns"
	value="$1"

	[ -f "$CAKE_SYNC_TIME_PATH" ] || return 0

	if [ -z "$value" ]; then
		value=$(uci get advanced.@defaults[0].cake_sync_time_ns 2>/dev/null || true)
	fi

	[ -n "$value" ] || return 0

	case "$value" in
		''|*[!0-9]*)
			logger -t advanced_setup "invalid cake_mq sync_time value '$value'"
			return 1
			;;
	esac

	echo "$value" > "$CAKE_SYNC_TIME_PATH"
	logger -t advanced_setup "cake_mq sync_time set to $(cat "$CAKE_SYNC_TIME_PATH" 2>/dev/null)"
}

usb_setup()
{
	usb2=$(uci get advanced.@defaults[0].usb_2 2>/dev/null || echo "x")
	if [ $usb2 == 1 ]; then
		logger -s "advanced_setup: USB Speed set to 2.0"
		echo 1 > /sys/bus/usb/devices/usb2/2-0:1.0/usb2-port1/disable
	elif [ $usb2 == 0 ]; then
		logger -s "advanced_setup: USB Speed set to 3.0"
		echo 0 > /sys/bus/usb/devices/usb2/2-0:1.0/usb2-port1/disable
	fi
	
	usbpower=$(uci get advanced.@defaults[0].usb_power 2>/dev/null || echo "x")
	if [ $usbpower == 1 ]; then
		logger -s "advanced_setup: USB Power ON"
		echo 1 > /sys/devices/platform/regulator-usb-vbus/usb_vbus_enable
	elif [ $usbpower == 0 ]; then
		logger -s "advanced_setup: USB Power OFF"
		echo 0 > /sys/devices/platform/regulator-usb-vbus/usb_vbus_enable
	fi
	
	USB2_PATH="/sys/bus/usb/devices/usb2/2-0:1.0/usb2-port1/disable"
	USBPOWER_PATH="/sys/devices/platform/regulator-usb-vbus/usb_vbus_enable"
	status2=$(cat "$USB2_PATH")
	statuspower=$(cat "$USBPOWER_PATH")
	if [ "$status2" -eq 1 ]; then
		logger -s "advanced_setup: USB Speed is set to 2.0"
	fi
	if [ "$statuspower" -eq 1 ]; then
		logger -s "advanced_setup: USB is power ON"
	else
		logger -s "advanced_setup: USB is power OFF"
	fi
	
}

service_triggers() {
    procd_add_reload_trigger advanced network
}

start_service() {
    if [ ! -f /tmp/smp_affinity_started ]; then
		delay=$(uci get advanced.@advanced_packet_steering[0].advanced_packet_steering_delay 2>/dev/null || echo "30")
		logger -s "smp_affinity: Starting with delay of $delay sec."
		sleep $delay
		echo 1 > /tmp/smp_affinity_started
	fi
	if [ "$(sync_mt7915e_module_options)" = "1" ]; then
		reprobe_mt7915e
	else
		advanced_runtime_setup
	fi
    logger -t advanced_setup "advanced_setup finished"
}

reload_service() {
    trigger="$1"
    case "$trigger" in
	        atf)
				logger -t advanced_setup "advanced_setup atf"
				sync_mt7915e_airtime_module_options >/dev/null
				if ! mt7915e_airtime_reboot_required; then
					hw_atf_setup
				fi
	            ;;
        usb)
			logger -t advanced_setup "advanced_setup usb"
            usb_setup
            ;;
	        wed)
			logger -t advanced_setup "advanced_setup wed"
			sync_mt7915e_wed_module_options >/dev/null
			;;
		cake)
			logger -t advanced_setup "advanced_setup cake"
			cake_mq_setup "$2"
			;;
        *)
			logger -t advanced_setup "advanced_setup generic"
			if [ ! -f /tmp/smp_affinity_started ]; then
				delay=$(uci get advanced.@advanced_packet_steering[0].advanced_packet_steering_delay 2>/dev/null || echo "30")
				logger -s "smp_affinity: Starting with delay of $delay sec."
				sleep $delay
				echo 1 > /tmp/smp_affinity_started
			fi
			if [ "$(sync_mt7915e_module_options)" = "1" ]; then
				reprobe_mt7915e
			else
				advanced_runtime_setup
			fi
			logger -t advanced_setup "advanced_setup finished"
            ;;
    esac
}

stop_service() {
    logger -t advanced_setup "No stop actions defined"
}
