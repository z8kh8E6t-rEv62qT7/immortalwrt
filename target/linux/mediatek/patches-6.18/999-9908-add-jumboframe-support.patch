+	if (length <= MTK_MAX_RX_LENGTH)
+		return MTK_MAX_RX_LENGTH;
+
+	return DIV_ROUND_UP(length, MTK_MAX_RX_LENGTH_UNIT) *
+	       MTK_MAX_RX_LENGTH_UNIT;
+}
