+static u16 mtk_tx_hash(struct net_device *dev, struct sk_buff *skb,
+		       struct net_device *sb_dev)
+{
+	u32 hash;
+	u16 qoffset = 0;
+	u16 rcount = READ_ONCE(dev->real_num_rx_queues);
+	u16 qcount = dev->real_num_tx_queues;
+
+	sb_dev = sb_dev ? : dev;
+
+	if (dev->num_tc) {
+		u8 tc = netdev_get_prio_tc_map(dev, skb->priority);
+
+		qoffset = sb_dev->tc_to_txq[tc].offset;
+		qcount = sb_dev->tc_to_txq[tc].count;
+		if (unlikely(!qcount)) {
+			qoffset = 0;
+			qcount = dev->real_num_tx_queues;
+		}
+	}
+
+	/* On single-RX-queue devices the recorded rx queue is usually 0 for
+	 * almost all forwarded traffic, which collapses most packets onto one
+	 * TX queue. Prefer the per-flow hash in that case.
+	 */
+	if (rcount > 1 && skb_rx_queue_recorded(skb)) {
+		hash = skb_get_rx_queue(skb);
+		if (hash >= qoffset)
+			hash -= qoffset;
+		while (unlikely(hash >= qcount))
+			hash -= qcount;
+		return hash + qoffset;
+	}
+
+	return reciprocal_scale(skb_get_hash(skb), qcount) + qoffset;
+}
+
 static u16 mtk_select_queue(struct net_device *dev, struct sk_buff *skb,
 			    struct net_device *sb_dev)
