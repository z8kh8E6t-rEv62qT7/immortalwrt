config unblockneteasemusic 'config'
	option replace_music_source 'dont_replace'
	option block_ads '1'
	option advanced_mode '1'
	option log_level 'silent'
	option http_port '5200'
	option https_port '5201'
	option self_issue_cert_crt '/usr/share/unblockneteasemusic/server.crt'
	option self_issue_cert_key '/usr/share/unblockneteasemusic/server.key'
	option strict_mode '1'
